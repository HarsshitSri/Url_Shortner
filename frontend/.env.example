# Railway public API URL (no trailing slash) — REQUIRED on Vercel
SHORTLINK_API_BASE=https://YOUR-SERVICE.up.railway.app

# Optional footer links
SHORTLINK_GITHUB_URL=https://github.com/HarsshitSri
SHORTLINK_LINKEDIN_URL=https://www.linkedin.com/in/harsshit

# After setting SHORTLINK_API_BASE: Redeploy Vercel (Build must run npm run build).
# Then on Railway set CORS_ALLOWED_ORIGINS to your exact Vercel origin, e.g.
#   https://url-shortner-xxx.vercel.app
# and redeploy the API.
