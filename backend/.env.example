# Database (local Docker or Neon)
# Local:
DATABASE_URL=jdbc:postgresql://localhost:5434/urlshortener
DATABASE_USERNAME=urlshortener
DATABASE_PASSWORD=urlshortener
# Neon (production / Railway) — also see deploy/railway.env.example:
# DATABASE_URL=jdbc:postgresql://ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_USERNAME=neondb_owner
# DATABASE_PASSWORD=
# Avoid embedding user:password in the URL and avoid channel_binding=require (JDBC rejects it).

# Application
APP_BASE_URL=http://localhost:8080
PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000
# Production: set APP_BASE_URL to Railway URL and CORS/FRONTEND to Vercel origin.

# Gemini (Google AI Studio)
# Leave empty for local runs without AI (soft fallback warnings still work).
# To enable live Gemini:
#   export GEMINI_API_KEY=your-key
#   export SPRING_AI_MODEL_CHAT=google-genai
GEMINI_API_KEY=
SPRING_AI_MODEL_CHAT=none
GEMINI_MODEL=gemini-2.0-flash

# JWT (v3 auth)
JWT_SECRET=local-dev-only-change-me-shortlink-jwt-secret-key-32b
JWT_EXPIRATION_MS=86400000

# Frontend URL used for OAuth redirects after Google/GitHub login
FRONTEND_BASE_URL=http://localhost:5500

# Google OAuth (optional — leave empty to hide the Google button)
# Create at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:8080/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# GitHub OAuth (optional — leave empty to hide the GitHub button)
# Create at https://github.com/settings/developers → OAuth Apps
# Authorization callback URL: http://localhost:8080/login/oauth2/code/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
