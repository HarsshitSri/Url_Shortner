# =============================================================================
# Railway — API service env (root directory: backend/)
# Copy into Railway → Variables. Replace every REPLACE_ME value.
# Dockerfile: backend/Dockerfile (see backend/railway.toml)
# =============================================================================

# --- Neon Postgres ---
# Prefer Neon "JDBC" connection details, OR paste a libpq URL — the app normalizes it.
# Best form (no user/pass in URL; no channel_binding):
DATABASE_URL=jdbc:postgresql://ep-xxxxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_USERNAME=neondb_owner
DATABASE_PASSWORD=REPLACE_ME

# Do NOT embed user:pass in DATABASE_URL.
# Do NOT use channel_binding=require (libpq). JDBC rejects it — use sslmode=require only.

# --- Public URLs (fill after first Railway + Vercel deploys, then redeploy API) ---
# Railway public domain, e.g. https://shortlink-api-production.up.railway.app
CORS_ALLOWED_ORIGINS=https://*.vercel.app,http://localhost:5500,http://127.0.0.1:5500
FRONTEND_BASE_URL=https://REPLACE_ME.vercel.app
APP_BASE_URL=https://REPLACE_ME.up.railway.app

# Railway injects PORT; keep this only if you override locally
# PORT=8080

# --- Auth ---
# Generate: openssl rand -base64 48
JWT_SECRET=REPLACE_ME_long_random_secret_at_least_32_bytes
JWT_EXPIRATION_MS=86400000

# --- AI (leave off for first deploy) ---
SPRING_AI_MODEL_CHAT=none
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- OAuth (optional — leave empty to hide buttons) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
